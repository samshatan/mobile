{
  "expo": {
    "name": "BrickOurHouse",
    "slug": "brick-our-house",
    "scheme": "buildingapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brickourhouse.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow BrickOurHouse to access your camera to upload profile pictures and documents.",
        "NSPhotoLibraryUsageDescription": "Allow BrickOurHouse to access your photos to upload documents."
      }
    },
    "android": {
      "package": "com.brickourhouse.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f7698a3c-a7d3-4f20-a706-f0977060cbb6"
      }
    }
  }
}
